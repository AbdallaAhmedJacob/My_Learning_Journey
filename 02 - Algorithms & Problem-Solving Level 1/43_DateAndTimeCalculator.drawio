        <mxCell id="Q8evddxTD6sH_B0KW9oE-4" value="&lt;div&gt;&lt;table class=&quot;NormalTable&quot;&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td width=&quot;383&quot;&gt;&lt;span class=&quot;fontstyle0&quot;&gt;SecondsPerDay = 24 * 60 * 60&lt;br&gt;&lt;br&gt;econdsPerHour = 60 * 60&lt;br&gt;&lt;br&gt;SecondsPerMinute = 60&lt;br&gt;&lt;br&gt;NumberOfDays = Floor(TotalSeconds /SecondsPerDay )&lt;br&gt;&lt;br&gt;Remainder = ToyalSeconds Mod SecondsPerDay&lt;br&gt;&lt;br&gt;NumberOfHours = Floor(Remainder / SecondsPerHours)&lt;br&gt;&lt;br&gt;Remainder = Remainder Mod SecondsPerHours&lt;br&gt;&lt;br&gt;NumberOfMinutes = Floor(Remainder / SecondsPerMinute)&lt;br&gt;&lt;br&gt;Remainder = Remainder Mod SecondsPerMinute&lt;br&gt;&lt;br&gt;NumberOfSeconds = Remainder&lt;/span&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt; &lt;br&gt;&lt;br style=&quot;font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; font-variant-emoji: normal; line-height: normal; text-align: -webkit-auto; text-size-adjust: auto;&quot;&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;fillColor=#67AB9F;" parent="1" vertex="1">
